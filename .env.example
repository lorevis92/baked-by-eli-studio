# ============================================================
# Baked by Eli — Studio Foto: variabili di ambiente
# Copia questo file in .env.local per lo sviluppo locale.
# Su Vercel: Settings → Environment Variables.
# ============================================================

# --- FAL.ai (obbligatoria per iniziare) ---
# Prendila su https://fal.ai/dashboard/keys
FAL_KEY=

# Modello FAL per l'editing (default: fal-ai/nano-banana/edit).
# Se in futuro vuoi cambiare modello, basta cambiare questa riga.
# FAL_MODEL_ID=fal-ai/nano-banana/edit

# --- Google Gemini (opzionale, predisposto) ---
# Prendila su https://aistudio.google.com/apikey
# Con questa chiave si attivano:
#  1) l'analisi automatica pre-editing (decide quali step servono)
#  2) il motore "Google Gemini" come alternativa a FAL
GOOGLE_API_KEY=

# Modello Google per l'editing immagini (default: gemini-2.5-flash-image).
# Nota: 2.5-flash-image è in dismissione a ottobre 2026 → quando pronto,
# passa a gemini-3.1-flash-image cambiando solo questa riga.
# GOOGLE_MODEL_ID=gemini-2.5-flash-image

# Modello Google per l'analisi (default: gemini-2.5-flash)
# GOOGLE_ANALYSIS_MODEL=gemini-2.5-flash

# --- Motore di default se entrambe le chiavi sono presenti ---
# valori: fal | google
# DEFAULT_PROVIDER=fal
